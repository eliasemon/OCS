# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google AI Configuration (fallback provider)
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Default model to use (free models)
# OpenRouter free options: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
# Google AI free options: gemini-1.5-flash, gemini-2.0-flash
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GOOGLE_AI_MODEL=gemini-2.0-flash

# App URL for OpenRouter referer header
NEXT_PUBLIC_APP_URL=https://installora.vercel.app
